# ──────────────────────────────────────────────
#  .env.example — Copie para .env e preencha
#  NÃO commite o .env real no repositório!
# ──────────────────────────────────────────────

# ── Telegram ────────────────────────────────
# Obtenha o token com @BotFather no Telegram
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Frontend Vue 3 (AWS) ────────────────────
# URL base do seu webapp sem barra final
FRONTEND_URL=https://seu-app.com

# ── Banco de dados SQLite ────────────────────
# Caminho do arquivo .db dentro do container
# (mapeado para um volume Docker para persistência)
DB_PATH=./data/subscriptions.db

# ── API interna ──────────────────────────────
# Porta que o servidor Express escutará
API_PORT=3001

# Chave secreta compartilhada com seu backend.
# O backend deve enviar: X-Api-Secret: <valor abaixo>
# Gere com: openssl rand -hex 32
API_SECRET=troque_por_uma_chave_segura_de_64_chars
