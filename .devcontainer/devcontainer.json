{
  "name": "MP Telegram Bot — Dev Environment",
  "dockerComposeFile": ["../docker-compose.dev.yml"],
  "service": "backend",
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Vue.volar",
        "bradlc.vscode-tailwindcss",
        "alexcvzz.vscode-sqlite",
        "ms-azuretools.vscode-docker",
        "christian-kohler.path-intellisense",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "terminal.integrated.defaultProfile.linux": "sh",
        "files.watcherExclude": {
          "**/node_modules/**": true,
          "**/.git/**": true
        }
      }
    }
  },
  "forwardPorts": [3000, 3001, 5173, 8080, 4040],
  "portsAttributes": {
    "3000": { "label": "Backend (Express)", "onAutoForward": "notify" },
    "3001": { "label": "Bot API Interna", "onAutoForward": "silent" },
    "5173": { "label": "Frontend (Vite)", "onAutoForward": "openBrowser" },
    "8080": { "label": "Gateway Nginx", "onAutoForward": "silent" },
    "4040": { "label": "Ngrok UI", "onAutoForward": "notify" }
  },
  "postCreateCommand": "echo '✅ Dev container pronto! Sem ngrok: http://localhost:5173 | Com ngrok: make dev-ngrok'",
  "remoteUser": "root"
}
