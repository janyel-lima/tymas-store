# ════════════════════════════════════════════════════════
#  .env.example — Variáveis de Ambiente da Stack Completa
#  Copie para .env (produção) ou .env.dev (desenvolvimento)
#  NUNCA commite o .env real no repositório!
# ════════════════════════════════════════════════════════

# ── Mercado Pago ─────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel
# Produção começa com APP_USR-, Sandbox com TEST-
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram ─────────────────────────────────────────────
# Token do bot (obtenha com @BotFather → /newbot)
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Username do bot (sem @), usado para gerar links de retorno
TELEGRAM_BOT_USERNAME=seu_bot_username

# ── URLs Públicas ─────────────────────────────────────────
# URL pública do backend (HTTPS obrigatório para webhooks do MP)
# Em dev com ngrok: https://xxxx.ngrok-free.app
BACKEND_URL=https://api.seu-dominio.com

# URL pública do frontend
FRONTEND_URL=https://seu-dominio.com

# ── Backend Interno ───────────────────────────────────────
# Porta do servidor Express
PORT=3000

# Ambiente (development | production)
NODE_ENV=production

# Caminho do banco SQLite (dentro do container)
DB_PATH=/app/data/payments.db

# ── Bot API Interna ───────────────────────────────────────
# Porta do servidor Express interno do bot
API_PORT=3001

# Chave secreta compartilhada entre backend e bot
# Para acionar o endpoint /activate do bot de forma segura
# Gere com: openssl rand -hex 32
API_SECRET=troque_por_uma_chave_segura_gerada_com_openssl_rand_hex_32

# ── Vite Build-time (Frontend) ────────────────────────────
# Essas variáveis são injetadas durante o build do Docker (ARG)
# e ficam hardcoded no bundle — não são segredos
VITE_BACKEND_URL=https://api.seu-dominio.com
VITE_FRONTEND_URL=https://seu-dominio.com
