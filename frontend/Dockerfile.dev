# ════════════════════════════════════════════════════════
#  frontend/Dockerfile.dev — Vite dev server com HMR
# ════════════════════════════════════════════════════════
FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install --legacy-peer-deps

COPY . .

ENV NODE_ENV=development

EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
