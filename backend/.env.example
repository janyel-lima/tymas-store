# ─────────────────────────────────────────────
#  Renomeie este arquivo para .env e preencha
# ─────────────────────────────────────────────

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente (development | production)
NODE_ENV=development

# Mercado Pago — Access Token (produção começa com APP_USR-)
# Obtenha em: https://www.mercadopago.com.br/developers/panel
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx

# Telegram Bot Token
# Obtenha com: @BotFather no Telegram → /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCDEFxxxxxxxxxxxxxxxxxxxxxxx

# URL pública do SEU backend (deve ser HTTPS e acessível pelo Mercado Pago)
# Em desenvolvimento, use ngrok: https://xxxx.ngrok-free.app
BASE_URL=https://seu-backend.com

# URL do frontend (para back_urls e CORS)
FRONTEND_URL=https://seu-frontend.com

# Caminho do arquivo SQLite
DB_PATH=./payments.db
